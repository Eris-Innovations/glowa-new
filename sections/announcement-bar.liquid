{%- comment -%}
  GLOWA announcement bar — full-width gold marquee.
  Doubles the track so the CSS `translateX(-50%)` produces a seamless loop.
{%- endcomment -%}

{%- assign repeat_count = section.settings.repeat | default: 6 -%}
{%- assign track_text = section.settings.text -%}

<section
  class="glowa-scope glowa-announcement"
  role="region"
  aria-label="Announcements"
  style="
    --glowa-marquee-speed: {{ section.settings.speed | default: 25 }}s;
    {% if section.settings.background_color != blank %}background: {{ section.settings.background_color }};{% endif %}
    {% if section.settings.text_color != blank %}color: {{ section.settings.text_color }};{% endif %}
  "
>
  <div class="glowa-announcement__track" aria-hidden="false">
    {%- for i in (1..2) -%}
      {%- for n in (1..repeat_count) -%}
        <span class="glowa-announcement__item">{{ track_text }}</span>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Announcement bar",
  "tag": "section",
  "class": "glowa-section-announcement",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Marquee text",
      "default": "For all skin types  —  Glow with confidence  —  Beauty in simplicity.  —  "
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#B8960C"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Animation speed",
      "min": 10,
      "max": 60,
      "step": 1,
      "unit": "s",
      "default": 25
    },
    {
      "type": "range",
      "id": "repeat",
      "label": "Repetitions per loop",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    }
  ],
  "presets": [
    { "name": "GLOWA Announcement bar" }
  ]
}
{% endschema %}
