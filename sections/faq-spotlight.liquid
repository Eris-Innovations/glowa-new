<section class="faq-spotlight section-{{ section.id }}">
  <div class="page-width faq-spotlight__grid">
    <div class="faq-spotlight__intro">
      <h2>{{ section.settings.heading }}</h2>
      <div class="faq-spotlight__text rte">{{ section.settings.text }}</div>
      <a href="{{ section.settings.button_link | default: '#' }}" class="button faq-spotlight__button">
        {{ section.settings.button_text }}
      </a>
    </div>

    <div class="faq-spotlight__product">
      {% if section.settings.product_image %}
        {{
          section.settings.product_image
          | image_url: width: 900
          | image_tag:
            loading: 'lazy',
            widths: '300, 450, 700, 900',
            sizes: '(min-width: 990px) 25vw, 60vw',
            alt: section.settings.heading
        }}
      {% endif %}
    </div>

    <div class="faq-spotlight__faqs">
      {% for block in section.blocks %}
        <details class="faq-spotlight__item" {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}>
          <summary>
            <span>{{ block.settings.question }}</span>
            <span class="faq-spotlight__icon"></span>
          </summary>
          <div class="faq-spotlight__answer rte">
            {{ block.settings.answer }}
          </div>
        </details>
      {% endfor %}
    </div>
  </div>
</section>

{%- style -%}
  .faq-spotlight {
    padding: 6.4rem 0;
    background: #fffdf8;
  }

  .faq-spotlight__grid {
    display: grid;
    gap: 3.2rem;
    align-items: center;
  }

  .faq-spotlight__intro h2 {
    margin: 0 0 1.6rem;
    color: #c4ab4c;
    font-size: clamp(3.2rem, 4vw, 5.6rem);
    line-height: 1;
  }

  .faq-spotlight__text {
    max-width: 34rem;
    color: rgba(43, 36, 27, 0.84);
  }

  .faq-spotlight__button.button {
    margin-top: 2.4rem;
    border: 0;
    background: #c6ad4a;
  }

  .faq-spotlight__product {
    justify-self: center;
  }

  .faq-spotlight__product img {
    display: block;
    width: min(100%, 22rem);
    height: auto;
    object-fit: contain;
  }

  .faq-spotlight__faqs {
    display: grid;
    gap: 1.2rem;
  }

  .faq-spotlight__item {
    border: 0.1rem solid rgba(56, 44, 20, 0.12);
    background: #ffffff;
  }

  .faq-spotlight__item summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.6rem;
    padding: 2rem;
    cursor: pointer;
    list-style: none;
    color: #201912;
    font-size: 2rem;
  }

  .faq-spotlight__item summary::-webkit-details-marker {
    display: none;
  }

  .faq-spotlight__icon {
    position: relative;
    width: 1.6rem;
    height: 1.6rem;
    flex: 0 0 auto;
  }

  .faq-spotlight__icon::before,
  .faq-spotlight__icon::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    background: #201912;
    transform: translate(-50%, -50%);
  }

  .faq-spotlight__icon::before {
    width: 1.4rem;
    height: 0.1rem;
  }

  .faq-spotlight__icon::after {
    width: 0.1rem;
    height: 1.4rem;
  }

  .faq-spotlight__item[open] .faq-spotlight__icon::after {
    display: none;
  }

  .faq-spotlight__answer {
    padding: 0 2rem 2rem;
    color: rgba(43, 36, 27, 0.78);
  }

  @media screen and (min-width: 990px) {
    .faq-spotlight__grid {
      grid-template-columns: minmax(0, 0.8fr) minmax(18rem, 0.45fr) minmax(0, 1fr);
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "FAQ Spotlight",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "We're answerable!"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>We create safe products that really work and are designed to make people feel good.</p><p>Use this section for shipping, packaging, and support questions.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "See More Answers"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How long does shipping take?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Shipping usually takes 3-7 business days depending on location.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Spotlight",
      "blocks": [
        { "type": "faq" },
        { "type": "faq", "settings": { "question": "Does my piece come in any packaging?" } },
        { "type": "faq", "settings": { "question": "Do you ship internationally?" } },
        { "type": "faq", "settings": { "question": "What payment methods do you accept?" } }
      ]
    }
  ]
}
{% endschema %}
