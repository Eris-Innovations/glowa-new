<section class="testimonials-showcase section-{{ section.id }}">
  <div class="page-width">
    <div class="testimonials-showcase__header">
      <h2>{{ section.settings.heading }}</h2>
    </div>

    <div class="testimonials-showcase__grid">
      {% for block in section.blocks %}
        <article class="testimonial-card testimonial-card--{{ block.settings.card_style }}" {{ block.shopify_attributes }}>
          {% if block.settings.card_style == 'image' %}
            <div class="testimonial-card__media">
              {% if block.settings.image %}
                {{
                  block.settings.image
                  | image_url: width: 1200
                  | image_tag:
                    loading: 'lazy',
                    widths: '360, 540, 720, 960, 1200',
                    sizes: '(min-width: 990px) 22vw, 44vw',
                    alt: block.settings.name
                }}
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </div>
          {% endif %}

          {% if block.settings.card_style == 'review' %}
            <div class="testimonial-card__body">
              <div class="testimonial-card__person">
                {% if block.settings.avatar %}
                  {{
                    block.settings.avatar
                    | image_url: width: 120
                    | image_tag:
                      loading: 'lazy',
                      widths: '60, 120',
                      sizes: '60px',
                      alt: block.settings.name
                  }}
                {% endif %}
                <div>
                  <h3>{{ block.settings.name }}</h3>
                  <p>{{ block.settings.role }}</p>
                </div>
              </div>

              <p class="testimonial-card__rating">
                {% for i in (1..block.settings.rating) %}★{% endfor %}
              </p>
              <div class="testimonial-card__quote rte">{{ block.settings.quote }}</div>

              {% if block.settings.product_name != blank %}
                <div class="testimonial-card__product">
                  {% if block.settings.product_image %}
                    {{
                      block.settings.product_image
                      | image_url: width: 120
                      | image_tag:
                        loading: 'lazy',
                        widths: '60, 120',
                        sizes: '60px',
                        alt: block.settings.product_name
                    }}
                  {% endif %}
                  <div>
                    <strong>{{ block.settings.product_name }}</strong>
                    <p>{{ block.settings.product_price }}</p>
                  </div>
                </div>
              {% endif %}
            </div>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{%- style -%}
  .testimonials-showcase {
    padding: 5.6rem 0;
    background: #fffdfa;
  }

  .testimonials-showcase__header {
    margin-bottom: 2.8rem;
  }

  .testimonials-showcase__header h2 {
    margin: 0;
    color: #262018;
    font-size: clamp(3.2rem, 4vw, 5.6rem);
    line-height: 1;
  }

  .testimonials-showcase__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .testimonial-card {
    overflow: hidden;
    border-radius: 2rem;
    background: #f7f4ec;
    min-height: 100%;
  }

  .testimonial-card--image .testimonial-card__media {
    aspect-ratio: 0.82;
  }

  .testimonial-card__media img,
  .testimonial-card__media svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .testimonial-card__body {
    display: flex;
    flex-direction: column;
    padding: 2.4rem;
    background: #fffdf8;
    border: 0.1rem solid rgba(52, 42, 22, 0.1);
    height: 100%;
    min-height: 100%;
  }

  .testimonial-card__person {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    padding-bottom: 1.8rem;
    border-bottom: 0.1rem solid rgba(52, 42, 22, 0.12);
  }

  .testimonial-card__person img {
    width: 5.4rem;
    height: 5.4rem;
    border-radius: 50%;
    object-fit: cover;
  }

  .testimonial-card__person h3,
  .testimonial-card__product strong {
    margin: 0;
    color: #2b241b;
    font-size: 2rem;
  }

  .testimonial-card__person p,
  .testimonial-card__product p {
    margin: 0.2rem 0 0;
    color: rgba(43, 36, 27, 0.72);
  }

  .testimonial-card__rating {
    margin: 1.8rem 0 1.2rem;
    color: #a77a58;
    font-size: 2.2rem;
    letter-spacing: 0.2rem;
  }

  .testimonial-card__quote {
    color: rgba(43, 36, 27, 0.82);
  }

  .testimonial-card__product {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    margin-top: auto;
    padding: 1.2rem 1.4rem;
    border-radius: 1.2rem;
    background: #f3f0e7;
  }

  .testimonial-card__product img {
    width: 4.8rem;
    height: 4.8rem;
    border-radius: 0.8rem;
    object-fit: cover;
  }

  @media screen and (min-width: 990px) {
    .testimonials-showcase__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Testimonials Showcase",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Customers love us."
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "select",
          "id": "card_style",
          "label": "Card style",
          "options": [
            { "value": "image", "label": "Image only" },
            { "value": "review", "label": "Review card" }
          ],
          "default": "review"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Main image"
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Mia D"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role",
          "default": "Verified Customer"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "richtext",
          "id": "quote",
          "label": "Quote",
          "default": "<p>Each product is crafted with thoughtful ingredients and a soft, premium feel.</p>"
        },
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Product image"
        },
        {
          "type": "text",
          "id": "product_name",
          "label": "Product name",
          "default": "Glow Serum"
        },
        {
          "type": "text",
          "id": "product_price",
          "label": "Product price",
          "default": "$60.00"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials Showcase",
      "blocks": [
        { "type": "testimonial", "settings": { "card_style": "image" } },
        { "type": "testimonial", "settings": { "card_style": "review" } },
        { "type": "testimonial", "settings": { "card_style": "image" } },
        { "type": "testimonial", "settings": { "card_style": "review" } }
      ]
    }
  ]
}
{% endschema %}
