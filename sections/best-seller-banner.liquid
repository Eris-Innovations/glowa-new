<section class="best-seller-banner section-{{ section.id }}">
  <div class="page-width">
    <div class="best-seller-banner__frame">
      <div class="best-seller-banner__copy">
        <h2>{{ section.settings.heading }}</h2>
      </div>

      <div class="best-seller-banner__media">
        {% if section.settings.image %}
          {{
            section.settings.image
            | image_url: width: 2000
            | image_tag:
              loading: 'lazy',
              widths: '720, 1100, 1600, 2000',
              sizes: '100vw',
              alt: section.settings.heading
          }}
        {% else %}
          {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>

      <a href="{{ section.settings.button_link | default: '#' }}" class="button best-seller-banner__button">
        {{ section.settings.button_text }}
      </a>
    </div>
  </div>
</section>

{%- style -%}
  .best-seller-banner {
    padding: 4rem 0 5.6rem;
    background: #fffdfa;
  }

  .best-seller-banner__frame {
    position: relative;
    overflow: hidden;
    border: 0.2rem solid rgba(255, 255, 255, 0.75);
    border-radius: 0.8rem;
    min-height: 52rem;
    background: linear-gradient(135deg, #bd7652 0%, #f4d5bf 48%, #fff7ef 100%);
  }

  .best-seller-banner__copy {
    position: absolute;
    top: 3.2rem;
    left: 3.2rem;
    z-index: 2;
    max-width: 34rem;
  }

  .best-seller-banner__copy h2 {
    margin: 0;
    color: #201912;
    font-size: clamp(3.6rem, 4vw, 6.2rem);
    line-height: 1;
  }

  .best-seller-banner__media {
    height: 100%;
    min-height: 52rem;
  }

  .best-seller-banner__media img,
  .best-seller-banner__media svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .best-seller-banner__button.button {
    --color-button: 207, 190, 121;
    --color-button-text: 255, 255, 255;
    position: absolute;
    right: 2.4rem;
    bottom: 2.4rem;
    z-index: 2;
    min-width: 20rem;
    border: 0;
    background: #cfbe79 !important;
    color: #ffffff !important;
  }

  .best-seller-banner__button.button::before {
    box-shadow: none !important;
  }

  .best-seller-banner__button.button::after,
  .best-seller-banner__button.button:hover::after,
  .best-seller-banner__button.button:focus-visible::after {
    background: #cfbe79 !important;
    box-shadow: 0 0 0 calc(var(--buttons-border-width) + var(--border-offset))
        rgba(255, 255, 255, 0),
      0 0 0 var(--buttons-border-width) rgba(207, 190, 121, 1);
  }

  @media screen and (max-width: 749px) {
    .best-seller-banner__copy {
      top: 2.4rem;
      left: 2.4rem;
      right: 2.4rem;
    }

    .best-seller-banner__button.button {
      left: 2.4rem;
      right: 2.4rem;
      min-width: 0;
      text-align: center;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Best Seller Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Best Sellers"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Best Seller Banner"
    }
  ]
}
{% endschema %}
