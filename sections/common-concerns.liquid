{%- comment -%}
  GLOWA — Common Concerns.
  Heading + subheading + 5-column grid of concern cards.
  Each card: portrait area (placeholder SVG silhouette by default) + label.
{%- endcomment -%}

<section class="glowa-scope glowa-concerns">
  <div class="glowa-container">

    <header class="glowa-concerns__header glowa-reveal">
      <h2 class="glowa-concerns__heading">{{ section.settings.heading | default: 'Common Concerns' }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="glowa-concerns__sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </header>

    <div class="glowa-concerns__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'concern' -%}
          {%- assign target_url = block.settings.link | default: '#' -%}
          <a class="glowa-concern glowa-reveal" href="{{ target_url }}" {{ block.shopify_attributes }}>
            <div class="glowa-concern__media">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 600 | image_tag:
                    loading: 'lazy',
                    widths: '300,600',
                    alt: block.settings.label
                }}
              {%- else -%}
                <svg class="glowa-concern__placeholder" viewBox="0 0 100 120" aria-hidden="true">
                  <rect x="0" y="0" width="100" height="120" fill="var(--color-bg)"/>
                  <circle cx="50" cy="45" r="18" fill="rgba(184, 150, 12, 0.18)"/>
                  <path
                    d="M22 110 Q22 78 50 78 Q78 78 78 110 L78 120 L22 120 Z"
                    fill="rgba(184, 150, 12, 0.18)"
                  />
                  <text
                    x="50"
                    y="115"
                    text-anchor="middle"
                    font-family="Cormorant Garamond, serif"
                    font-size="14"
                    font-style="italic"
                    fill="rgba(107, 100, 40, 0.55)"
                  >{{ block.settings.label | slice: 0 | upcase }}</text>
                </svg>
              {%- endif -%}
            </div>
            <span class="glowa-concern__label">{{ block.settings.label | default: 'Aging' }}</span>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Common concerns",
  "tag": "section",
  "class": "glowa-section-concerns",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Common Concerns"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Not sure where to start? Our formulas are crafted for real skin, whatever it's going through."
    }
  ],
  "blocks": [
    {
      "type": "concern",
      "name": "Concern",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Aging"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Portrait image (optional)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "GLOWA Common concerns",
      "settings": {
        "heading": "Common Concerns",
        "subheading": "Not sure where to start? Our formulas are crafted for real skin, whatever it's going through."
      },
      "blocks": [
        { "type": "concern", "settings": { "label": "Aging" } },
        { "type": "concern", "settings": { "label": "Congestion" } },
        { "type": "concern", "settings": { "label": "Texture" } },
        { "type": "concern", "settings": { "label": "Redness" } },
        { "type": "concern", "settings": { "label": "Dryness" } }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["index", "page", "collection"]
  }
}
{% endschema %}
