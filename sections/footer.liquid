{%- comment -%}
  GLOWA — Footer.
  4-col top: newsletter, shop, customer care, about.
  Bottom: country + copyright (left)  |  socials + legal + payments (right).
{%- endcomment -%}

<footer class="glowa-scope glowa-footer" role="contentinfo">
  <div class="glowa-footer__inner">

    <div class="glowa-footer__top">

      <div class="glowa-footer__col glowa-footer__col--newsletter glowa-reveal">
        <h3 class="glowa-footer__newsletter-heading">{{ section.settings.newsletter_heading | default: 'Subscribe to get 10% OFF' }}</h3>
        <p class="glowa-footer__newsletter-sub">{{ section.settings.newsletter_subtext | default: 'Subscribe for store updates and discounts.' }}</p>

        {%- form 'customer', class: 'glowa-newsletter-form', novalidate: 'novalidate' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <label for="glowa-footer-email" class="visually-hidden">Email</label>
          <div class="glowa-newsletter-form__field">
            <input
              type="email"
              name="contact[email]"
              id="glowa-footer-email"
              placeholder="{{ section.settings.email_placeholder | default: 'Email' }}"
              required
              autocomplete="email"
            >
            <button type="submit" aria-label="Subscribe">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                <polyline points="9 6 15 12 9 18"></polyline>
              </svg>
            </button>
          </div>

          {%- liquid
            assign terms_url = section.settings.terms_url
            if terms_url == blank and shop.terms_of_service.url != blank
              assign terms_url = shop.terms_of_service.url
            endif
            if terms_url == blank
              assign terms_url = '/policies/terms-of-service'
            endif

            assign privacy_url_resolved = section.settings.privacy_url
            if privacy_url_resolved == blank and shop.privacy_policy.url != blank
              assign privacy_url_resolved = shop.privacy_policy.url
            endif
            if privacy_url_resolved == blank
              assign privacy_url_resolved = '/policies/privacy-policy'
            endif
          -%}
          {%- liquid
            assign show_terms = false
            if section.settings.terms_label != blank
              assign show_terms = true
            endif
            assign show_privacy = false
            if section.settings.privacy_label != blank
              assign show_privacy = true
            endif
          -%}
          {%- if show_terms or show_privacy -%}
            <p class="glowa-newsletter-form__fine">
              {{- section.settings.fine_prefix | default: 'By subscribing you agree to the ' -}}
              {%- if show_terms -%}
                <a href="{{ terms_url }}">{{ section.settings.terms_label }}</a>
              {%- endif -%}
              {%- if show_terms and show_privacy -%}
                {{- section.settings.fine_separator | default: ' & ' -}}
              {%- endif -%}
              {%- if show_privacy -%}
                <a href="{{ privacy_url_resolved }}">{{ section.settings.privacy_label }}</a>
              {%- endif -%}
              {{- section.settings.fine_suffix | default: '.' -}}
            </p>
          {%- endif -%}

          {%- if form.posted_successfully? -%}
            <div class="glowa-newsletter-form__status glowa-newsletter-form__status--success" role="status" tabindex="-1" data-glowa-newsletter-status>
              <svg class="glowa-newsletter-form__status-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 6 9 17l-5-5"/>
              </svg>
              <span class="glowa-newsletter-form__status-text">
                <strong>You're subscribed to GLOWA.</strong>
                <span>Check your inbox for your 10% off code.</span>
              </span>
            </div>
          {%- elsif form.errors -%}
            <div class="glowa-newsletter-form__status glowa-newsletter-form__status--error" role="alert" tabindex="-1" data-glowa-newsletter-status>
              <svg class="glowa-newsletter-form__status-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="8" x2="12" y2="13"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
              </svg>
              <span class="glowa-newsletter-form__status-text">
                {{ form.errors | default_errors }}
              </span>
            </div>
          {%- endif -%}
        {%- endform -%}
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'links' -%}
          <div class="glowa-footer__col glowa-footer__col--links glowa-reveal" {{ block.shopify_attributes }}>
            <h4 class="glowa-footer__col-heading">{{ block.settings.heading }}</h4>
            <ul class="glowa-footer__links">
              {%- if block.settings.menu != blank -%}
                {%- for link in linklists[block.settings.menu].links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              {%- else -%}
                {%- comment -%}
                  Each line in the "Links" textarea can be either:
                    Label                         → renders as label only (no link)
                    Label|/path                   → renders as <a href="/path">Label</a>
                    Label|https://example.com     → external links work too
                {%- endcomment -%}
                {%- assign items = block.settings.links | newline_to_br | split: '<br />' -%}
                {%- for item in items -%}
                  {%- assign trimmed = item | strip -%}
                  {%- if trimmed != blank -%}
                    {%- assign parts = trimmed | split: '|' -%}
                    {%- assign link_label = parts[0] | strip -%}
                    {%- assign link_url = parts[1] | strip -%}
                    {%- if link_url != blank -%}
                      <li><a href="{{ link_url }}">{{ link_label }}</a></li>
                    {%- else -%}
                      <li><span>{{ link_label }}</span></li>
                    {%- endif -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
            </ul>
          </div>
        {%- elsif block.type == 'about' -%}
          <div class="glowa-footer__col glowa-footer__col--about glowa-reveal" {{ block.shopify_attributes }}>
            <h4 class="glowa-footer__col-heading">{{ block.settings.heading }}</h4>
            <p class="glowa-footer__about-body">{{ block.settings.body }}</p>
            {%- if block.settings.link_label != blank -%}
              <a class="glowa-footer__about-link" href="{{ block.settings.link_url | default: '#' }}">
                {{ block.settings.link_label }}
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="glowa-footer__bottom">
      <div class="glowa-footer__bottom-left">
        {%- if section.settings.show_country -%}
          <div class="glowa-footer__country">
            <span class="glowa-footer__country-flag" aria-hidden="true">
              {%- if section.settings.country_flag_image != blank -%}
                {{ section.settings.country_flag_image | image_url: width: 32 | image_tag: loading: 'lazy', alt: 'flag' }}
              {%- else -%}
                <svg viewBox="0 0 24 16" aria-hidden="true">
                  <rect x="0" y="0" width="8"  height="16" fill="#FFFFFF"/>
                  <rect x="8" y="0" width="16" height="16" fill="#8D1B3D"/>
                  <path d="M8 0 L11 2 L8 4 L11 6 L8 8 L11 10 L8 12 L11 14 L8 16 Z" fill="#FFFFFF"/>
                </svg>
              {%- endif -%}
            </span>
            {%- if localization.available_countries.size > 1 -%}
              {%- form 'localization', class: 'glowa-footer__country-form' -%}
                <select name="country_code" onchange="this.form.submit()">
                  {%- for country in localization.available_countries -%}
                    <option value="{{ country.iso_code }}" {% if country.iso_code == localization.country.iso_code %}selected{% endif %}>
                      {{ country.name }} ({{ country.currency.iso_code }})
                    </option>
                  {%- endfor -%}
                </select>
              {%- endform -%}
            {%- else -%}
              <span class="glowa-footer__country-text">{{ section.settings.country_text | default: 'Qatar (Riyal)' }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- assign current_year = 'now' | date: '%Y' -%}
        {%- assign copyright_text = section.settings.copyright | default: '© 2026 GLOWA.' | replace: '[year]', current_year -%}
        <span class="glowa-footer__copyright">{{ copyright_text }}</span>
      </div>

      <div class="glowa-footer__bottom-right">
        <ul class="glowa-footer__social" aria-label="Social media">
          {%- for block in section.blocks -%}
            {%- if block.type == 'social' -%}
              <li {{ block.shopify_attributes }}>
                <a href="{{ block.settings.url | default: '#' }}" target="_blank" rel="noopener" aria-label="{{ block.settings.network }}">
                  {%- case block.settings.network -%}
                    {%- when 'facebook' -%}
                      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12a10 10 0 1 0-11.6 9.9v-7H8v-3h2.4V9.7c0-2.4 1.4-3.7 3.6-3.7 1 0 2.1.2 2.1.2v2.3h-1.2c-1.2 0-1.5.7-1.5 1.5V12h2.6l-.4 3h-2.2v7A10 10 0 0 0 22 12z"/></svg>
                    {%- when 'twitter' -%}
                      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2H21l-6.55 7.49L22 22h-6.844l-4.79-6.27L4.8 22H2l7.02-8.03L2 2h7l4.33 5.72L18.244 2z"/></svg>
                    {%- when 'instagram' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
                    {%- when 'tiktok' -%}
                      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.6 6.4a5.4 5.4 0 0 1-3.2-1.7v8.7a5.6 5.6 0 1 1-5.6-5.6c.3 0 .6 0 .9.1v2.7a2.9 2.9 0 1 0 2 2.7V2h2.7a5.4 5.4 0 0 0 3.2 4.4v2z"/></svg>
                    {%- when 'pinterest' -%}
                      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-3.6 19.3c-.1-.8-.2-2.1 0-3l1.2-5s-.3-.6-.3-1.6c0-1.5.9-2.6 2-2.6.9 0 1.4.7 1.4 1.5 0 .9-.6 2.3-.9 3.6-.3 1.1.6 2 1.6 2 2 0 3.5-2.1 3.5-5.1 0-2.7-1.9-4.5-4.7-4.5-3.2 0-5 2.4-5 4.8 0 .9.4 2 .8 2.5.1.1.1.2.1.3-.1.3-.3 1.1-.3 1.3 0 .2-.2.2-.4.1-1.5-.7-2.4-2.9-2.4-4.6 0-3.8 2.7-7.2 7.9-7.2 4.1 0 7.4 3 7.4 6.9 0 4.1-2.6 7.5-6.2 7.5-1.2 0-2.4-.7-2.8-1.4l-.7 2.8c-.3 1.1-1 2.4-1.5 3.3A10 10 0 1 0 12 2z"/></svg>
                    {%- when 'youtube' -%}
                      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 8.2s-.2-1.5-.8-2.1c-.7-.8-1.5-.8-1.9-.9-2.6-.2-6.6-.2-6.6-.2s-4 0-6.6.2c-.4 0-1.2.1-1.9.9-.6.6-.8 2.1-.8 2.1S3 10 3 11.7v1.6c0 1.7.2 3.5.2 3.5s.2 1.5.8 2.1c.7.8 1.7.8 2.1.9 1.6.1 6.9.2 6.9.2s4 0 6.6-.2c.4 0 1.2-.1 1.9-.9.6-.6.8-2.1.8-2.1s.2-1.7.2-3.5v-1.6C22.2 10 22 8.2 22 8.2zM9.8 14.8V8.6l5.2 3.1-5.2 3.1z"/></svg>
                    {%- else -%}
                      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><circle cx="12" cy="12" r="9"/></svg>
                  {%- endcase -%}
                </a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>

        {%- liquid
          assign legal_one_url = section.settings.legal_one_url
          if legal_one_url == blank and shop.privacy_policy.url != blank
            assign legal_one_url = shop.privacy_policy.url
          endif
          if legal_one_url == blank
            assign legal_one_url = '/policies/privacy-policy'
          endif

          assign legal_two_url = section.settings.legal_two_url
          if legal_two_url == blank and shop.terms_of_service.url != blank
            assign legal_two_url = shop.terms_of_service.url
          endif
          if legal_two_url == blank
            assign legal_two_url = '/policies/terms-of-service'
          endif

          assign legal_three_url = section.settings.legal_three_url
          if legal_three_url == blank and shop.refund_policy.url != blank
            assign legal_three_url = shop.refund_policy.url
          endif
          if legal_three_url == blank
            assign legal_three_url = '/policies/refund-policy'
          endif
        -%}
        <div class="glowa-footer__legal-row">
          <div class="glowa-footer__legal">
            {%- if section.settings.legal_one_label != blank -%}
              <a href="{{ legal_one_url }}">{{ section.settings.legal_one_label }}</a>
            {%- endif -%}
            {%- if section.settings.legal_two_label != blank -%}
              <a href="{{ legal_two_url }}">{{ section.settings.legal_two_label }}</a>
            {%- endif -%}
            {%- if section.settings.legal_three_label != blank -%}
              <a href="{{ legal_three_url }}">{{ section.settings.legal_three_label }}</a>
            {%- endif -%}
          </div>

          {%- if section.settings.show_payments -%}
            <div class="glowa-footer__payments" aria-label="Accepted payment methods">
            {%- assign payment_methods = section.settings.payment_methods | split: ',' -%}
            {%- for raw in payment_methods -%}
              {%- assign pm = raw | strip | downcase -%}
              <span class="glowa-footer__payment glowa-footer__payment--{{ pm }}" aria-label="{{ pm }}">
                {%- case pm -%}
                  {%- when 'visa' -%}
                    <svg viewBox="0 0 38 24" aria-hidden="true">
                      <rect width="38" height="24" rx="3" fill="#1A1F71"/>
                      <text x="19" y="16" text-anchor="middle" font-family="Arial, sans-serif" font-size="9" font-weight="700" font-style="italic" fill="#FFFFFF" letter-spacing="0.5">VISA</text>
                    </svg>
                  {%- when 'mc' or 'mastercard' -%}
                    <svg viewBox="0 0 38 24" aria-hidden="true">
                      <rect width="38" height="24" rx="3" fill="#FFFFFF" stroke="#E0E0E0"/>
                      <circle cx="16" cy="12" r="6" fill="#EB001B"/>
                      <circle cx="22" cy="12" r="6" fill="#F79E1B"/>
                      <path d="M19 7.5a6 6 0 0 1 0 9 6 6 0 0 1 0-9z" fill="#FF5F00"/>
                    </svg>
                  {%- when 'amex' -%}
                    <svg viewBox="0 0 38 24" aria-hidden="true">
                      <rect width="38" height="24" rx="3" fill="#006FCF"/>
                      <text x="19" y="11" text-anchor="middle" font-family="Arial, sans-serif" font-size="5" font-weight="700" fill="#FFFFFF">AMERICAN</text>
                      <text x="19" y="17" text-anchor="middle" font-family="Arial, sans-serif" font-size="5" font-weight="700" fill="#FFFFFF">EXPRESS</text>
                    </svg>
                  {%- when 'pp' or 'paypal' -%}
                    <svg viewBox="0 0 38 24" aria-hidden="true">
                      <rect width="38" height="24" rx="3" fill="#FFFFFF" stroke="#E0E0E0"/>
                      <text x="19" y="15" text-anchor="middle" font-family="Arial, sans-serif" font-size="8" font-weight="700" font-style="italic" fill="#003087">Pay</text>
                      <text x="26" y="15" text-anchor="middle" font-family="Arial, sans-serif" font-size="8" font-weight="700" font-style="italic" fill="#009CDE">Pal</text>
                    </svg>
                  {%- when 'din' or 'diners' -%}
                    <svg viewBox="0 0 38 24" aria-hidden="true">
                      <rect width="38" height="24" rx="3" fill="#FFFFFF" stroke="#E0E0E0"/>
                      <circle cx="19" cy="12" r="8" fill="#0079BE"/>
                      <path d="M15 5.5a7 7 0 0 0 0 13zM23 5.5a7 7 0 0 1 0 13z" fill="#FFFFFF"/>
                    </svg>
                  {%- when 'disc' or 'discover' -%}
                    <svg viewBox="0 0 38 24" aria-hidden="true">
                      <rect width="38" height="24" rx="3" fill="#FFFFFF" stroke="#E0E0E0"/>
                      <path d="M0 18 Q19 26 38 16 V21 Q38 24 35 24 H3 Q0 24 0 21 Z" fill="#F47216"/>
                      <text x="19" y="11" text-anchor="middle" font-family="Arial, sans-serif" font-size="5" font-weight="700" fill="#1A1A1A">DISCOVER</text>
                    </svg>
                  {%- else -%}
                    <span class="glowa-footer__payment-text">{{ pm | upcase }}</span>
                {%- endcase -%}
              </span>
            {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "footer",
  "class": "glowa-section-footer",
  "settings": [
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Subscribe to get 10% OFF"
    },
    {
      "type": "text",
      "id": "newsletter_subtext",
      "label": "Newsletter subtext",
      "default": "Subscribe for store updates and discounts."
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email input placeholder",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "fine_prefix",
      "label": "Fine print — prefix",
      "default": "By subscribing you agree to the "
    },
    {
      "type": "text",
      "id": "terms_label",
      "label": "Terms link label",
      "default": "Terms of Use"
    },
    {
      "type": "url",
      "id": "terms_url",
      "label": "Terms link URL",
      "info": "Leave empty to auto-link to your Shopify Terms of Service policy."
    },
    {
      "type": "text",
      "id": "fine_separator",
      "label": "Fine print — separator",
      "default": " & "
    },
    {
      "type": "text",
      "id": "privacy_label",
      "label": "Privacy link label",
      "default": "Privacy Policy"
    },
    {
      "type": "url",
      "id": "privacy_url",
      "label": "Privacy link URL",
      "info": "Leave empty to auto-link to your Shopify Privacy Policy."
    },
    {
      "type": "text",
      "id": "fine_suffix",
      "label": "Fine print — suffix",
      "default": "."
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "checkbox",
      "id": "show_country",
      "label": "Show country selector",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "country_flag_image",
      "label": "Country flag (image)"
    },
    {
      "type": "text",
      "id": "country_text",
      "label": "Country fallback text",
      "default": "Qatar (Riyal)"
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright text",
      "default": "© 2026 GLOWA."
    },
    {
      "type": "text",
      "id": "legal_one_label",
      "label": "Legal link 1 — label",
      "default": "Privacy Policy"
    },
    {
      "type": "url",
      "id": "legal_one_url",
      "label": "Legal link 1 — URL",
      "info": "Leave empty to auto-link to your Shopify Privacy Policy."
    },
    {
      "type": "text",
      "id": "legal_two_label",
      "label": "Legal link 2 — label",
      "default": "Terms of Service"
    },
    {
      "type": "url",
      "id": "legal_two_url",
      "label": "Legal link 2 — URL",
      "info": "Leave empty to auto-link to your Shopify Terms of Service policy."
    },
    {
      "type": "text",
      "id": "legal_three_label",
      "label": "Legal link 3 — label",
      "default": "Refund Policy"
    },
    {
      "type": "url",
      "id": "legal_three_url",
      "label": "Legal link 3 — URL",
      "info": "Leave empty to auto-link to your Shopify Refund Policy."
    },
    {
      "type": "checkbox",
      "id": "show_payments",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "text",
      "id": "payment_methods",
      "label": "Payment methods (comma-separated)",
      "info": "Accepts: visa, mc, amex, pp, din, disc",
      "default": "visa, mc, amex, pp, din, disc"
    }
  ],
  "blocks": [
    {
      "type": "links",
      "name": "Links column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu (optional, overrides text list)"
        },
        {
          "type": "textarea",
          "id": "links",
          "label": "Links (one per line)",
          "default": "Shop All\nSale\nLookbook\nBasic Collections"
        }
      ]
    },
    {
      "type": "about",
      "name": "About column",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "About"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body",
          "default": "We only carry designs we believe in ethically and aesthetically – original, authentic pieces that are made to last."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "info": "Leave empty to hide the link entirely."
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    },
    {
      "type": "social",
      "name": "Social icon",
      "settings": [
        {
          "type": "select",
          "id": "network",
          "label": "Network",
          "options": [
            { "value": "facebook",  "label": "Facebook" },
            { "value": "twitter",   "label": "X (Twitter)" },
            { "value": "instagram", "label": "Instagram" },
            { "value": "tiktok",    "label": "TikTok" },
            { "value": "pinterest", "label": "Pinterest" },
            { "value": "youtube",   "label": "YouTube" }
          ],
          "default": "facebook"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "GLOWA Footer",
      "settings": {
        "newsletter_heading": "Subscribe to get 10% OFF",
        "newsletter_subtext": "Subscribe for store updates and discounts.",
        "email_placeholder": "Email",
        "fine_prefix": "By subscribing you agree to the ",
        "terms_label": "Terms of Use",
        "fine_separator": " & ",
        "privacy_label": "Privacy Policy",
        "fine_suffix": ".",
        "show_country": true,
