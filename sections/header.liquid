{%- comment -%}
  GLOWA header — sticky, white background with subtle bottom border.
  Loads the global GLOWA stylesheet and script once for every page.
{%- endcomment -%}

{{ 'glowa-theme.css' | asset_url | stylesheet_tag }}
<script src="{{ 'glowa-theme.js' | asset_url }}" defer="defer"></script>

{%- assign cart_count = cart.item_count -%}
{%- assign nav_menu = linklists[section.settings.menu] -%}

<header class="glowa-scope glowa-header" role="banner">
  <div class="glowa-header__inner">

    <div class="glowa-header__brand">
      <button
        type="button"
        class="glowa-header__burger"
        aria-label="Open menu"
        data-glowa-drawer-open
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          <line x1="3" y1="6"  x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>

      <a href="{{ routes.root_url }}" class="glowa-header__logo" aria-label="{{ shop.name | escape }} home">
        {%- if section.settings.logo_image != blank -%}
          {{ section.settings.logo_image | image_url: width: 800 | image_tag:
              loading: 'eager',
              widths: '200,400,600,800',
              sizes: '(max-width: 768px) 140px, 200px',
              alt: section.settings.logo_text,
              class: 'glowa-header__logo-img'
          }}
        {%- elsif section.settings.use_default_logo -%}
          <img
            src="{{ 'glowa-logo.png' | asset_url }}"
            srcset="{{ 'glowa-logo.png' | asset_url }} 1x"
            alt="{{ section.settings.logo_text | default: 'GLOWA' }}"
            class="glowa-header__logo-img"
            loading="eager"
            width="200"
            height="44"
          >
        {%- else -%}
          <span class="glowa-header__logo-text">{{ section.settings.logo_text | default: 'GLOWA' }}</span>
        {%- endif -%}
      </a>
    </div>

    <nav class="glowa-header__nav" role="navigation" aria-label="Main navigation">
      {%- if nav_menu != blank and nav_menu.links.size > 0 -%}
        {%- for link in nav_menu.links -%}
          <a
            href="{{ link.url }}"
            {% if link.current %}class="is-active" aria-current="page"{% endif %}
          >{{ link.title }}</a>
        {%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'nav_link' -%}
            {%- assign url = block.settings.link | default: routes.root_url -%}
            {%- assign is_active = false -%}
            {%- if request.path == url -%}{%- assign is_active = true -%}{%- endif -%}
            <a
              href="{{ url }}"
              {% if is_active or block.settings.force_active %}class="is-active" aria-current="page"{% endif %}
              {{ block.shopify_attributes }}
            >{{ block.settings.label }}</a>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </nav>

    <div class="glowa-header__actions">
      {%- if section.settings.show_search -%}
        <a href="{{ routes.search_url }}" class="glowa-header__action" aria-label="Search" style="color:#CFBE79;">
          <svg viewBox="0 0 24 24" fill="none" stroke="#CFBE79" stroke-width="1.6" aria-hidden="true">
            <circle cx="11" cy="11" r="7"></circle>
            <line x1="16.5" y1="16.5" x2="21" y2="21"></line>
          </svg>
        </a>
      {%- endif -%}

      {%- if section.settings.show_account -%}
        <a
          href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}"
          class="glowa-header__action"
          aria-label="Account"
          style="color:#CFBE79;"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="#CFBE79" stroke-width="1.6" aria-hidden="true">
            <circle cx="12" cy="8" r="4"></circle>
            <path d="M4 21c0-4 4-6 8-6s8 2 8 6"></path>
          </svg>
        </a>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" class="glowa-header__action" aria-label="Cart" style="color:#CFBE79;">
        <svg viewBox="0 0 24 24" fill="none" stroke="#CFBE79" stroke-width="1.6" aria-hidden="true">
          <path d="M6 7h12l-1.2 11.1A2 2 0 0 1 14.8 20H9.2a2 2 0 0 1-2-1.9L6 7z"></path>
          <path d="M9 7V5a3 3 0 0 1 6 0v2"></path>
        </svg>
        <span class="glowa-header__cart-count" data-glowa-cart-count data-count="{{ cart_count }}">
          {{- cart_count -}}
        </span>
      </a>
    </div>
  </div>
</header>

<div class="glowa-drawer" data-glowa-drawer aria-hidden="true">
  <div class="glowa-drawer__panel" role="dialog" aria-modal="true" aria-label="Menu">
    <button type="button" class="glowa-drawer__close" data-glowa-drawer-close aria-label="Close menu">&times;</button>
    <ul class="glowa-drawer__nav">
      {%- if nav_menu != blank and nav_menu.links.size > 0 -%}
        {%- for link in nav_menu.links -%}
          <li>
            <a
              href="{{ link.url }}"
              {% if link.current %}class="is-active"{% endif %}
              data-glowa-drawer-close
            >{{ link.title }}</a>
          </li>
        {%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'nav_link' -%}
            <li>
              <a
                href="{{ block.settings.link | default: routes.root_url }}"
                {{ block.shopify_attributes }}
                data-glowa-drawer-close
              >{{ block.settings.label }}</a>
            </li>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </ul>
  </div>
</div>

{% style %}
  .glowa-header {
    {% if section.settings.background_color != blank %}
      background: {{ section.settings.background_color }};
    {% endif %}
    --glowa-logo-height: {{ section.settings.logo_height | default: 44 }}px;
  }
{% endstyle %}

{% schema %}
{
  "name": "Header",
  "tag": "section",
  "class": "glowa-section-header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image",
      "info": "Recommended: PNG with transparent background, ~400px wide. Leave empty to use the bundled GLOWA wordmark."
    },
    {
      "type": "checkbox",
      "id": "use_default_logo",
      "label": "Use bundled GLOWA wordmark",
      "info": "When checked and no custom logo is uploaded, the gold GLOWA wordmark (assets/glowa-logo.png) is shown.",
      "default": true
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo height",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 44
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text (fallback)",
      "default": "GLOWA"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "info": "If empty, the nav_link blocks below are used."
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show account icon",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "nav_link",
      "name": "Navigation link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Home"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "force_active",
          "label": "Mark as active",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "GLOWA Header",
      "settings": {
        "logo_text": "GLOWA",
        "background_color": "#FFFFFF",
        "show_search": true,
        "show_account": true
      },
      "blocks": [
        { "type": "nav_link", "settings": { "label": "Home",    "link": "/" } },
        { "type": "nav_link", "settings": { "label": "Product", "link": "/collections/all", "force_active": true } },
        { "type": "nav_link", "settings": { "label": "Contact", "link": "/pages/contact" } }
      ]
    }
  ]
}
{% endschema %}
