{%- comment -%}
  GLOWA — Bestsellers / New Releases tab section.
  Two tabs, each tab shows a 5-column product card grid.

  Data source priority per tab:
    1. A merchant-picked Shopify collection (settings.bestsellers_collection
       and settings.new_releases_collection).
    2. Static `card` blocks scoped to that tab.
{%- endcomment -%}

{%- liquid
  assign max = section.settings.products_per_tab | default: 5

  assign bs_collection = section.settings.bestsellers_collection
  assign nr_collection = section.settings.new_releases_collection

  if bs_collection == blank
    assign bs_collection = collections['all']
  endif

  if nr_collection == blank
    assign nr_collection = collections['all']
  endif

  assign bs_count = 0
  assign nr_count = 0
  if bs_collection != blank
    assign bs_count = bs_collection.products_count | at_most: max
  endif
  if nr_collection != blank
    assign nr_count = nr_collection.products_count | at_most: max
  endif

  if bs_count == 0
    for block in section.blocks
      if block.type == 'card' and block.settings.tab != 'new-releases'
        assign bs_count = bs_count | plus: 1
      endif
    endfor
  endif
  if nr_count == 0
    for block in section.blocks
      if block.type == 'card' and block.settings.tab == 'new-releases'
        assign nr_count = nr_count | plus: 1
      endif
    endfor
  endif
-%}

<section class="glowa-scope glowa-bestsellers" data-glowa-tabs>
  <div class="glowa-container">

    {%- if section.settings.banner_image != blank or section.settings.banner_asset != blank -%}
      <div class="glowa-bestsellers__banner glowa-reveal">
        {%- if section.settings.banner_image != blank -%}
          {{ section.settings.banner_image | image_url: width: 2000 | image_tag:
              loading: 'lazy',
              widths: '800,1200,1600,2000',
              alt: section.settings.banner_alt | default: 'GLOWA bestseller products lineup',
              class: 'glowa-bestsellers__banner-img'
          }}
        {%- else -%}
          <img
            src="{{ section.settings.banner_asset | asset_url }}"
            alt="{{ section.settings.banner_alt | default: 'GLOWA bestseller products lineup' | escape }}"
            loading="lazy"
            width="2000"
            height="950"
            class="glowa-bestsellers__banner-img"
          >
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="glowa-bestsellers__tabs" role="tablist">
      <button
        type="button"
        class="glowa-bestsellers__tab is-active"
        role="tab"
        aria-selected="true"
        aria-controls="bs-panel-bestsellers"
        data-glowa-tab="bestsellers"
      >
        {{ section.settings.tab_one_label | default: 'Bestsellers' }}
        {%- if bs_count > 0 -%}<sup class="glowa-bestsellers__count">{{ bs_count }}</sup>{%- endif -%}
      </button>
      <button
        type="button"
        class="glowa-bestsellers__tab"
        role="tab"
        aria-selected="false"
        aria-controls="bs-panel-new-releases"
        data-glowa-tab="new-releases"
      >
        {{ section.settings.tab_two_label | default: 'New Releases' }}
        {%- if nr_count > 0 -%}<sup class="glowa-bestsellers__count">{{ nr_count }}</sup>{%- endif -%}
      </button>
    </div>

    {%- assign tab_keys = 'bestsellers,new-releases' | split: ',' -%}
    {%- for tab in tab_keys -%}
      {%- liquid
        if tab == 'bestsellers'
          assign tab_collection = bs_collection
        else
          assign tab_collection = nr_collection
        endif
      -%}
      <div
        class="glowa-bestsellers__panel{% if tab == 'bestsellers' %} is-active{% endif %}"
        id="bs-panel-{{ tab }}"
        role="tabpanel"
        data-glowa-tab-panel="{{ tab }}"
        {% if tab != 'bestsellers' %}hidden{% endif %}
      >
        <div class="glowa-bestsellers__grid">

          {%- if tab_collection != blank and tab_collection.products_count > 0 -%}
            {%- if tab == 'new-releases' -%}
              {%- assign tab_products = tab_collection.products | sort: 'published_at' | reverse -%}
            {%- else -%}
              {%- assign tab_products = tab_collection.products -%}
            {%- endif -%}
            {%- assign rendered = 0 -%}
            {%- for cp in tab_products -%}
              {%- if rendered >= max -%}{%- break -%}{%- endif -%}
              {%- assign rendered = rendered | plus: 1 -%}
              {%- assign cp_variant   = cp.selected_or_first_available_variant -%}
              {%- assign size_option  = cp.options_with_values.first -%}
              {%- assign cp_rating    = blank -%}
              {%- assign cp_reviews   = blank -%}
              {%- if cp.metafields.reviews.rating.value != blank -%}
                {%- assign cp_rating = cp.metafields.reviews.rating.value.rating | default: cp.metafields.reviews.rating.value -%}
              {%- endif -%}
              {%- if cp.metafields.reviews.rating_count != blank -%}
                {%- assign cp_reviews = cp.metafields.reviews.rating_count.value | default: cp.metafields.reviews.rating_count -%}
              {%- endif -%}

              <article class="glowa-mini-card glowa-reveal" data-glowa-product>
                <span class="glowa-mini-card__badge">{{ section.settings.card_badge | default: 'Bestseller' }}</span>

                <button
                  type="button"
                  class="glowa-mini-card__wishlist"
                  aria-label="Add to wishlist"
                  data-product-id="{{ cp.id }}"
                >
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                    <path d="M12 21s-7-4.35-9.5-9A5.5 5.5 0 0 1 12 5.5 5.5 5.5 0 0 1 21.5 12c-2.5 4.65-9.5 9-9.5 9z"></path>
                  </svg>
                </button>

                <a href="{{ cp.url }}" class="glowa-mini-card__media" aria-label="{{ cp.title | escape }}">
                  {%- if cp.featured_image != blank -%}
                    {{ cp.featured_image | image_url: width: 400 | image_tag:
                        loading: 'lazy', widths: '200,400', alt: cp.title
                    }}
                  {%- else -%}
                    {%- assign placeholder_index = forloop.index0 | modulo: 6 | plus: 1 -%}
                    {{ 'product-' | append: placeholder_index | placeholder_svg_tag: 'glowa-mini-card__placeholder-svg' }}
                  {%- endif -%}
                </a>

                <h3 class="glowa-mini-card__name"><a href="{{ cp.url }}">{{ cp.title | truncate: 70 }}</a></h3>

                {%- if cp_rating != blank -%}
                  <div class="glowa-mini-card__rating">
                    <span class="glowa-stars" aria-hidden="true">★★★★</span><span class="glowa-stars glowa-stars--half" aria-hidden="true">★</span>
                    <span class="glowa-mini-card__rating-value">{{ cp_rating }}</span>
                    {%- if cp_reviews != blank -%}<span class="glowa-mini-card__review-count">({{ cp_reviews }})</span>{%- endif -%}
                  </div>
                {%- endif -%}

                <form method="post" action="{{ routes.cart_add_url }}" data-glowa-product-form>
                  <input type="hidden" name="form_type" value="product">
                  <input type="hidden" name="id" value="{{ cp_variant.id }}" data-glowa-variant-id>
                  <input type="hidden" name="quantity" value="1">

                  <div class="glowa-mini-card__meta">
                    <span class="glowa-mini-card__price" data-glowa-price>{{ cp_variant.price | money }}</span>
                    {%- if size_option != blank and size_option.values.size > 1 -%}
                      <span class="glowa-mini-card__sizes" data-glowa-size-group>
                        {%- for v in cp.variants limit: 2 -%}
                          {%- assign opt_value = v.options.first -%}
                          <button
                            type="button"
                            class="glowa-mini-card__size{% if v.id == cp_variant.id %} is-active{% endif %}"
                            data-value="{{ opt_value }}"
                            data-variant-id="{{ v.id }}"
                            data-price="{{ v.price | money }}"
                            data-available="{{ v.available }}"
                          >{{ opt_value }}</button>
                          {%- unless forloop.last -%}<span class="glowa-mini-card__sep" aria-hidden="true">|</span>{%- endunless -%}
                        {%- endfor -%}
                      </span>
                    {%- endif -%}
                  </div>

                  <button type="submit" class="glowa-mini-card__cta" data-glowa-add-to-cart>{{ section.settings.cta_label | default: 'Add To Cart' }}</button>
                </form>
              </article>
            {%- endfor -%}

          {%- else -%}

            {%- for block in section.blocks -%}
              {%- if block.type == 'card' -%}
                {%- assign block_tab = block.settings.tab | default: 'bestsellers' -%}
                {%- if block_tab == tab -%}
                  <article class="glowa-mini-card glowa-reveal" {{ block.shopify_attributes }}>
                    {%- if block.settings.badge != blank -%}
                      <span class="glowa-mini-card__badge">{{ block.settings.badge }}</span>
                    {%- endif -%}

                    <button
                      type="button"
                      class="glowa-mini-card__wishlist"
                      aria-label="Add to wishlist"
                      data-product-id="bs-{{ section.id }}-{{ forloop.index }}"
                    >
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                        <path d="M12 21s-7-4.35-9.5-9A5.5 5.5 0 0 1 12 5.5 5.5 5.5 0 0 1 21.5 12c-2.5 4.65-9.5 9-9.5 9z"></path>
                      </svg>
                    </button>

                    <div class="glowa-mini-card__media">
                      {%- if block.settings.image != blank -%}
                        {{ block.settings.image | image_url: width: 400 | image_tag:
                            loading: 'lazy', widths: '200,400', alt: block.settings.name
                        }}
                      {%- else -%}
                        {%- assign placeholder_index = forloop.index0 | modulo: 6 | plus: 1 -%}
                        {{ 'product-' | append: placeholder_index | placeholder_svg_tag: 'glowa-mini-card__placeholder-svg' }}
                      {%- endif -%}
                    </div>

                    <h3 class="glowa-mini-card__name">{{ block.settings.name | default: 'Glow Serum' }}</h3>

                    <div class="glowa-mini-card__rating">
                      <span class="glowa-stars" aria-hidden="true">★★★★</span><span class="glowa-stars glowa-stars--half" aria-hidden="true">★</span>
                      <span class="glowa-mini-card__rating-value">{{ block.settings.rating | default: '4.4' }}</span>
                      <span class="glowa-mini-card__review-count">({{ block.settings.review_count | default: '2754' }})</span>
                    </div>

                    <div class="glowa-mini-card__meta">
                      <span class="glowa-mini-card__price">{{ block.settings.price | default: '$6.00 USD' }}</span>
                      <span class="glowa-mini-card__sizes">
                        <button type="button" class="glowa-mini-card__size">{{ block.settings.size_one | default: '30ml' }}</button>
                        <span class="glowa-mini-card__sep" aria-hidden="true">|</span>
                        <button type="button" class="glowa-mini-card__size is-active">{{ block.settings.size_two | default: '60ml' }}</button>
                      </span>
                    </div>

                    <button type="button" class="glowa-mini-card__cta">{{ section.settings.cta_label | default: 'Add To Cart' }}</button>
                  </article>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}

          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

<script>
  (() => {
    const wraps = document.querySelectorAll('[data-glowa-tabs]');
    wraps.forEach((wrap) => {
      const tabs = Array.from(wrap.querySelectorAll('[data-glowa-tab]'));
      const panels = Array.from(wrap.querySelectorAll('[data-glowa-tab-panel]'));
      if (!tabs.length || !panels.length) return;

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const target = tab.dataset.glowaTab;

          tabs.forEach((item) => {
            const active = item === tab;
            item.classList.toggle('is-active', active);
            item.setAttribute('aria-selected', active ? 'true' : 'false');
          });

          panels.forEach((panel) => {
            const active = panel.dataset.glowaTabPanel === target;
            panel.classList.toggle('is-active', active);
            panel.hidden = !active;
          });
        });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Bestsellers tabs",
  "tag": "section",
  "class": "glowa-section-bestsellers",
  "settings": [
    {
      "type": "header",
      "content": "Hero banner"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner image"
    },
    {
      "type": "text",
      "id": "banner_asset",
      "label": "Theme asset filename",
      "info": "Falls back to this image inside the assets folder when no image is picked above. e.g. bestsellers-banner.png"
    },
    {
      "type": "text",
      "id": "banner_alt",
      "label": "Banner alt text",
      "default": "GLOWA bestseller products lineup"
    },
    {
      "type": "header",
      "content": "Tabs"
    },
    {
      "type": "text",
      "id": "tab_one_label",
      "label": "Tab 1 label",
      "default": "Bestsellers"
    },
    {
      "type": "text",
      "id": "tab_two_label",
      "label": "Tab 2 label",
      "default": "New Releases"
    },
    {
      "type": "header",
      "content": "Live data (recommended)"
    },
    {
      "type": "collection",
      "id": "bestsellers_collection",
      "label": "Bestsellers — collection",
      "info": "If set, products from this Shopify collection populate the first tab. Static cards below are used as fallback."
    },
    {
      "type": "collection",
      "id": "new_releases_collection",
      "label": "New Releases — collection",
      "info": "If set, products from this Shopify collection populate the second tab."
    },
    {
      "type": "range",
      "id": "products_per_tab",
      "label": "Max products per tab",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 5
    },
    {
      "type": "text",
      "id": "card_badge",
      "label": "Card top-left label (live data)",
      "default": "Bestseller"
    },
    {
      "type": "header",
      "content": "Card CTA"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Card CTA label",
      "default": "Add To Cart"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Static card (fallback)",
      "settings": [
        {
          "type": "select",
          "id": "tab",
          "label": "Tab",
          "options": [
            { "value": "bestsellers",  "label": "Bestsellers" },
            { "value": "new-releases", "label": "New Releases" }
          ],
          "default": "bestsellers"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Product name",
          "default": "Glow Serum"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product image (optional)"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Top-left label",
          "default": "Bestseller"
        },
        {
          "type": "text",
          "id": "rating",
          "label": "Star rating value",
          "default": "4.4"
        },
        {
          "type": "text",
          "id": "review_count",
          "label": "Review count",
          "default": "2754"
        },
        {
          "type": "text",
          "id": "tags",
          "label": "Tag list",
          "default": "Oil Control, Brightens, Smooths"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "$6.00 USD"
        },
        {
          "type": "text",
          "id": "size_one",
          "label": "Size option 1",
          "default": "30ml"
        },
        {
          "type": "text",
          "id": "size_two",
          "label": "Size option 2",
          "default": "60ml"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "GLOWA Bestsellers tabs",
      "settings": {
        "tab_one_label": "Bestsellers",
        "tab_two_label": "New Releases",
        "cta_label": "Add To Cart",
        "card_badge": "Bestseller",
        "products_per_tab": 5
      }
    }
  ],
  "enabled_on": {
    "templates": ["index", "page", "collection"]
  }
}
{% endschema %}
