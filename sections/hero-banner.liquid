<section class="hero-banner section-{{ section.id }}">
  <div class="page-width hero-banner__inner">
    <div class="hero-banner__content">
      <p class="hero-banner__eyebrow">{{ section.settings.eyebrow }}</p>
      <h1>{{ section.settings.heading }}</h1>
      <p class="hero-banner__subheading">{{ section.settings.subheading }}</p>

      <a href="{{ section.settings.button_link | default: '#' }}" class="button hero-banner__button">
        {{ section.settings.button_text }}
      </a>
    </div>

    {% if section.settings.hero_image %}
      <div class="hero-banner__media">
        {{
          section.settings.hero_image
          | image_url: width: 1600
          | image_tag:
            loading: 'eager',
            widths: '480, 720, 960, 1200, 1600',
            sizes: '(min-width: 990px) 54vw, 100vw',
            alt: section.settings.heading
        }}
      </div>
    {% endif %}
  </div>
</section>

{%- style -%}
  .hero-banner {
    background:
      radial-gradient(circle at center, rgba(205, 175, 74, 0.12), transparent 58%),
      linear-gradient(180deg, #fffcf6 0%, #fff7ec 100%);
    overflow: hidden;
  }

  .hero-banner__inner {
    display: grid;
    align-items: center;
    gap: 3.2rem;
    min-height: 68rem;
    padding-top: 4.8rem;
    padding-bottom: 4.8rem;
  }

  .hero-banner__content {
    max-width: 48rem;
    z-index: 1;
  }

  .hero-banner__eyebrow {
    margin: 0 0 1.6rem;
    color: #927a12;
    font-size: 1.8rem;
    letter-spacing: 0;
  }

  .hero-banner h1 {
    margin: 0;
    color: #9e8110;
    font-size: clamp(4.8rem, 7vw, 8.8rem);
    line-height: 0.95;
    letter-spacing: -0.08rem;
  }

  .hero-banner__subheading {
    margin: 2rem 0 3.2rem;
    max-width: 34rem;
    color: rgba(69, 53, 18, 0.8);
    font-size: 1.8rem;
    line-height: 1.6;
  }

  .hero-banner__button.button {
    min-width: 18rem;
    background: #c7b04f;
    color: #fffef8;
    border: 0;
  }

  .hero-banner__media {
    position: relative;
    justify-self: end;
    width: min(100%, 78rem);
  }

  .hero-banner__media img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 24px 60px rgba(147, 116, 34, 0.14));
  }

  @media screen and (min-width: 990px) {
    .hero-banner__inner {
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    }
  }

  @media screen and (max-width: 989px) {
    .hero-banner__inner {
      min-height: auto;
      padding-top: 3.2rem;
      padding-bottom: 3.2rem;
    }

    .hero-banner__content {
      order: 1;
    }

    .hero-banner__media {
      justify-self: center;
      order: 2;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Blend beauty in you"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Beauty Starts Here"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sub Heading",
      "default": "A calm, bright skincare landing page designed for Glowa."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
