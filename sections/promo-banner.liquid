{%- comment -%}
  GLOWA — Promo banner (interactive bestsellers hero).
  Full-bleed image background with a soft scrim overlay,
  decorative gold corner brackets, animated sparkles, a floating
  "bestseller" badge, eyebrow + heading + subtitle, a stats strip
  and a CTA with a sliding arrow.
{%- endcomment -%}

{%- liquid
  assign min_height = section.settings.min_height | default: 480
  assign cta_bg = section.settings.cta_bg | default: '#B8960C'
  assign cta_color = section.settings.cta_color | default: '#FFFFFF'
  assign heading_color = section.settings.heading_color | default: '#1A1A1A'
  assign accent_color = section.settings.accent_color | default: '#B8960C'
  assign text_color = section.settings.text_color | default: '#3F3A33'
  assign overlay_color = section.settings.overlay_color | default: '#FBE4DD'
  assign overlay_opacity = section.settings.overlay_opacity | default: 55
  assign overlay_decimal = overlay_opacity | times: 0.01
  assign content_align = section.settings.content_align | default: 'left'
-%}

<section
  class="glowa-scope glowa-promo-banner glowa-promo-banner--{{ content_align }}"
  style="
    --glowa-promo-min-height: {{ min_height }}px;
    --glowa-promo-accent: {{ accent_color }};
    --glowa-promo-text: {{ text_color }};
    --glowa-promo-overlay: {{ overlay_color }};
    --glowa-promo-overlay-opacity: {{ overlay_decimal }};
    --glowa-promo-cta-bg: {{ cta_bg }};
    --glowa-promo-cta-color: {{ cta_color }};
    --glowa-promo-heading: {{ heading_color }};
  "
>
  <div class="glowa-promo-banner__container">
    <div class="glowa-promo-banner__frame">
      {%- comment -%} Background image {%- endcomment -%}
      <div class="glowa-promo-banner__media" aria-hidden="true">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 2200 | image_tag:
              loading: 'lazy',
              widths: '800,1200,1600,2000,2200',
              sizes: '100vw',
              alt: section.settings.heading,
              class: 'glowa-promo-banner__img'
          }}
        {%- elsif section.settings.image_asset != blank -%}
          <img
            src="{{ section.settings.image_asset | asset_url }}"
            alt="{{ section.settings.heading | escape }}"
            loading="lazy"
            width="2200"
            height="900"
            class="glowa-promo-banner__img"
          >
        {%- else -%}
          <div class="glowa-promo-banner__placeholder" aria-hidden="true"></div>
        {%- endif -%}
      </div>

      {%- comment -%} Soft scrim that fades from a tinted overlay on the
         content side to fully transparent on the product side. {%- endcomment -%}
      <div class="glowa-promo-banner__scrim" aria-hidden="true"></div>

      {%- comment -%} Decorative gold corner brackets {%- endcomment -%}
      <span class="glowa-promo-banner__bracket glowa-promo-banner__bracket--tl" aria-hidden="true"></span>
      <span class="glowa-promo-banner__bracket glowa-promo-banner__bracket--tr" aria-hidden="true"></span>
      <span class="glowa-promo-banner__bracket glowa-promo-banner__bracket--bl" aria-hidden="true"></span>
      <span class="glowa-promo-banner__bracket glowa-promo-banner__bracket--br" aria-hidden="true"></span>

      {%- comment -%} Animated sparkles {%- endcomment -%}
      <svg class="glowa-promo-banner__sparkle glowa-promo-banner__sparkle--1" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 2 L13.5 9.2 L20.7 10.7 L13.5 12.2 L12 19.4 L10.5 12.2 L3.3 10.7 L10.5 9.2 Z" fill="currentColor"/>
      </svg>
      <svg class="glowa-promo-banner__sparkle glowa-promo-banner__sparkle--2" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 4 L13 9 L18 10 L13 11 L12 16 L11 11 L6 10 L11 9 Z" fill="currentColor"/>
      </svg>
      <svg class="glowa-promo-banner__sparkle glowa-promo-banner__sparkle--3" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 5 L12.7 10 L17.7 10.7 L12.7 11.3 L12 16.3 L11.3 11.3 L6.3 10.7 L11.3 10 Z" fill="currentColor"/>
      </svg>

      {%- comment -%} Floating bestseller badge {%- endcomment -%}
      {%- if section.settings.badge_label != blank -%}
        <div class="glowa-promo-banner__badge" aria-hidden="true">
          <svg viewBox="0 0 24 24" class="glowa-promo-banner__badge-icon" aria-hidden="true">
            <path d="M12 2 L14.5 8.5 L21 9 L16 13.5 L17.5 20 L12 16.5 L6.5 20 L8 13.5 L3 9 L9.5 8.5 Z"
                  fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
          </svg>
          <span>{{ section.settings.badge_label }}</span>
        </div>
      {%- endif -%}

      {%- comment -%} Content panel {%- endcomment -%}
      <div class="glowa-promo-banner__content">
        {%- if section.settings.eyebrow != blank -%}
          <span class="glowa-promo-banner__eyebrow">
            <span class="glowa-promo-banner__eyebrow-line" aria-hidden="true"></span>
            {{ section.settings.eyebrow }}
          </span>
        {%- endif -%}

        <h2 class="glowa-promo-banner__heading">
          {{ section.settings.heading | default: 'Our Best Sellers' }}
        </h2>

        {%- if section.settings.subtitle != blank -%}
          <p class="glowa-promo-banner__subtitle">
            {{ section.settings.subtitle }}
          </p>
        {%- endif -%}

        {%- comment -%} Stats strip (visible only if at least one stat is set) {%- endcomment -%}
        {%- assign has_stats = false -%}
        {%- if section.settings.stat_1_value != blank or section.settings.stat_2_value != blank or section.settings.stat_3_value != blank -%}
          {%- assign has_stats = true -%}
        {%- endif -%}

        {%- if has_stats -%}
          <ul class="glowa-promo-banner__stats" role="list">
            {%- if section.settings.stat_1_value != blank -%}
              <li class="glowa-promo-banner__stat">
                <span class="glowa-promo-banner__stat-value">{{ section.settings.stat_1_value }}</span>
                <span class="glowa-promo-banner__stat-label">{{ section.settings.stat_1_label }}</span>
              </li>
            {%- endif -%}
            {%- if section.settings.stat_2_value != blank -%}
              <li class="glowa-promo-banner__stat">
                <span class="glowa-promo-banner__stat-value">{{ section.settings.stat_2_value }}</span>
                <span class="glowa-promo-banner__stat-label">{{ section.settings.stat_2_label }}</span>
              </li>
            {%- endif -%}
            {%- if section.settings.stat_3_value != blank -%}
              <li class="glowa-promo-banner__stat">
                <span class="glowa-promo-banner__stat-value">{{ section.settings.stat_3_value }}</span>
                <span class="glowa-promo-banner__stat-label">{{ section.settings.stat_3_label }}</span>
              </li>
            {%- endif -%}
          </ul>
        {%- endif -%}

        {%- if section.settings.cta_label != blank -%}
          <a
            href="{{ section.settings.cta_link | default: '#' }}"
            class="glowa-promo-banner__cta"
          >
            <span class="glowa-promo-banner__cta-label">{{ section.settings.cta_label }}</span>
            <span class="glowa-promo-banner__cta-arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M5 12 H19 M13 6 L19 12 L13 18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <span class="glowa-promo-banner__cta-shine" aria-hidden="true"></span>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Promo banner",
  "tag": "section",
  "class": "glowa-section-promo-banner",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Editor's picks"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Best Sellers"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Hand-picked Korean skincare loved by thousands. Real glass-skin results — every single day."
    },
    {
      "type": "text",
      "id": "badge_label",
      "label": "Floating badge label",
      "default": "Top rated 2026"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Content alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Stats strip"
    },
    {
      "type": "text",
      "id": "stat_1_value",
      "label": "Stat 1 — value",
      "default": "4.9★"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 — label",
      "default": "12,400 reviews"
    },
    {
      "type": "text",
      "id": "stat_2_value",
      "label": "Stat 2 — value",
      "default": "200K+"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 — label",
      "default": "Happy faces"
    },
    {
      "type": "text",
      "id": "stat_3_value",
      "label": "Stat 3 — value",
      "default": "100%"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 — label",
      "default": "K-Beauty authentic"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "image_asset",
      "label": "Image asset filename",
      "info": "Falls back to this image inside the assets folder when no image is picked above. e.g. bestsellers-banner.png",
      "default": "bestsellers-banner.png"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height",
      "min": 320,
      "max": 720,
      "step": 20,
      "unit": "px",
      "default": 480
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay tint",
      "default": "#FBE4DD"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 55
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body text color",
      "default": "#3F3A33"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color (gold)",
      "default": "#B8960C"
    },
    {
      "type": "header",
      "content": "CTA"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "cta_bg",
      "label": "Button background",
      "default": "#B8960C"
    },
    {
      "type": "color",
      "id": "cta_color",
      "label": "Button text color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "GLOWA Promo banner",
      "settings": {
        "heading": "Our Best Sellers",
        "eyebrow": "Editor's picks",
        "subtitle": "Hand-picked Korean skincare loved by thousands. Real glass-skin results — every single day.",
        "badge_label": "Top rated 2026",
        "content_align": "left",
        "min_height": 480,
        "overlay_color": "#FBE4DD",
        "overlay_opacity": 55,
        "cta_label": "Shop now",
        "cta_bg": "#B8960C",
        "cta_color": "#FFFFFF",
        "accent_color": "#B8960C"
      }
    }
  ],
  "enabled_on": {
    "templates": ["index", "page", "collection"]
  }
}
{% endschema %}
