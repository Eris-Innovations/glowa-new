{%- comment -%}
  GLOWA — Promo banner.
  Pink-to-peach gradient strip with an inset white frame.
  Heading top-left, product placeholder cluster center-right, CTA bottom-right.
  Reusable: works for "Best Sellers", "Coming Soon", "Limited Edition", etc.
{%- endcomment -%}

{%- liquid
  assign gradient_start = section.settings.gradient_start | default: '#F5C5C0'
  assign gradient_end = section.settings.gradient_end | default: '#E8C4B0'
  assign min_height = section.settings.min_height | default: 360
  assign cta_bg = section.settings.cta_bg | default: '#6B6428'
  assign cta_color = section.settings.cta_color | default: '#FFFFFF'
  assign heading_color = section.settings.heading_color | default: '#1A1A1A'
  assign frame_color = section.settings.frame_color | default: '#FFFFFF'
-%}

<section
  class="glowa-scope glowa-promo-banner"
  style="
    --glowa-promo-min-height: {{ min_height }}px;
    --glowa-promo-frame: {{ frame_color }};
    background: linear-gradient(90deg, {{ gradient_start }} 0%, {{ gradient_end }} 100%);
  "
>
  <div class="glowa-container glowa-promo-banner__container">
    <div class="glowa-promo-banner__frame">
      <h2
        class="glowa-promo-banner__heading"
        style="color: {{ heading_color }};"
      >
        {{ section.settings.heading | default: 'Our Best Sellers' }}
      </h2>

      <div class="glowa-promo-banner__media" aria-hidden="true">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1400 | image_tag:
              loading: 'lazy',
              widths: '600,900,1200,1400',
              sizes: '(max-width: 768px) 100vw, 60vw',
              alt: section.settings.heading,
              class: 'glowa-promo-banner__img'
          }}
        {%- elsif section.settings.image_asset != blank -%}
          <img
            src="{{ section.settings.image_asset | asset_url }}"
            alt="{{ section.settings.heading | escape }}"
            loading="lazy"
            width="1400"
            height="660"
            class="glowa-promo-banner__img"
          >
        {%- else -%}
          {%- comment -%} Stylized 5-bottle silhouette cluster as placeholder {%- endcomment -%}
          <svg
            class="glowa-promo-banner__placeholder"
            viewBox="0 0 600 280"
            preserveAspectRatio="xMidYMax meet"
          >
            <defs>
              <linearGradient id="glowaShelf-{{ section.id }}" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="rgba(255,255,255,0.65)"/>
                <stop offset="100%" stop-color="rgba(255,255,255,0)"/>
              </linearGradient>
            </defs>

            <ellipse cx="300" cy="245" rx="220" ry="18" fill="rgba(0,0,0,0.07)"/>

            <rect x="160" y="222" width="280" height="22" rx="2" fill="rgba(255,255,255,0.85)"/>
            <rect x="160" y="218" width="280" height="6" fill="rgba(255,255,255,0.95)"/>
            <rect x="160" y="222" width="280" height="22" rx="2" fill="url(#glowaShelf-{{ section.id }})"/>

            <g opacity="0.92">
              <rect x="68"  y="130" width="58"  height="92"  rx="6" fill="#E08A95"/>
              <rect x="78"  y="120" width="38"  height="14"  rx="3" fill="#C57080"/>
              <rect x="78"  y="170" width="38"  height="22"  rx="2" fill="#FFFFFF" opacity="0.85"/>
              <text x="97" y="187" text-anchor="middle" font-family="Jost, sans-serif" font-size="11" font-weight="700" fill="#1A1A1A">10+</text>
            </g>

            <g opacity="0.95">
              <path d="M150 222 L150 145 Q150 130 165 130 L195 130 Q210 130 210 145 L210 222 Z" fill="#FAF4EC"/>
              <rect x="170" y="100" width="20" height="34" rx="3" fill="#E5D9C6"/>
              <circle cx="180" cy="100" r="6" fill="#B8AB94"/>
              <rect x="160" y="170" width="40" height="24" rx="2" fill="#FFFFFF" opacity="0.85"/>
            </g>

            <g opacity="0.95">
              <path d="M232 222 L232 110 Q232 96 246 96 L274 96 Q288 96 288 110 L288 222 Z" fill="#F2EAD9"/>
              <rect x="245" y="80" width="30" height="18" rx="3" fill="#D9CFB7"/>
              <rect x="240" y="150" width="40" height="30" rx="2" fill="#FFFFFF" opacity="0.7"/>
            </g>

            <g opacity="0.95">
              <ellipse cx="335" cy="222" rx="38" ry="6" fill="rgba(0,0,0,0.08)"/>
              <rect x="305" y="170" width="60" height="52" rx="4" fill="#FAF4EC"/>
              <rect x="305" y="170" width="60" height="10" fill="#E8E0CC"/>
            </g>

            <g opacity="0.95">
              <path d="M385 222 L385 168 Q385 156 397 156 L427 156 Q439 156 439 168 L439 222 Z" fill="#F0D9B6"/>
              <rect x="397" y="138" width="18" height="22" rx="3" fill="#FFFFFF"/>
              <circle cx="406" cy="138" r="5" fill="#D6BFA2"/>
              <rect x="395" y="180" width="34" height="20" rx="2" fill="#FFFFFF" opacity="0.7"/>
            </g>

            <rect x="450" y="195" width="90" height="50" fill="#FFFFFF" opacity="0.4"/>
            <rect x="450" y="195" width="90" height="6" fill="#FFFFFF" opacity="0.8"/>
          </svg>
        {%- endif -%}
      </div>

      {%- if section.settings.cta_label != blank -%}
        <a
          href="{{ section.settings.cta_link | default: '#' }}"
          class="glowa-promo-banner__cta"
          style="background: {{ cta_bg }}; color: {{ cta_color }};"
        >
          {{ section.settings.cta_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Promo banner",
  "tag": "section",
  "class": "glowa-section-promo-banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Best Sellers"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1A1A1A"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "gradient_start",
      "label": "Gradient start (left)",
      "default": "#F5C5C0"
    },
    {
      "type": "color",
      "id": "gradient_end",
      "label": "Gradient end (right)",
      "default": "#E8C4B0"
    },
    {
      "type": "color",
      "id": "frame_color",
      "label": "Inset frame color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height",
      "min": 240,
      "max": 600,
      "step": 20,
      "unit": "px",
      "default": 360
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product image (optional)",
      "info": "Leave empty to show the placeholder product cluster."
    },
    {
      "type": "text",
      "id": "image_asset",
      "label": "Image asset filename",
      "info": "Falls back to this image inside the assets folder when no image is picked above. e.g. bestsellers-banner.png",
      "default": "bestsellers-banner.png"
    },
    {
      "type": "header",
      "content": "CTA"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "cta_bg",
      "label": "Button background",
      "default": "#6B6428"
    },
    {
      "type": "color",
      "id": "cta_color",
      "label": "Button text color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "GLOWA Promo banner",
      "settings": {
        "heading": "Our Best Sellers",
        "heading_color": "#1A1A1A",
        "gradient_start": "#F5C5C0",
        "gradient_end": "#E8C4B0",
        "frame_color": "#FFFFFF",
        "min_height": 360,
        "cta_label": "Shop Now",
        "cta_bg": "#6B6428",
        "cta_color": "#FFFFFF"
      }
    }
  ],
  "enabled_on": {
    "templates": ["index", "page", "collection"]
  }
}
{% endschema %}
